# AI Studio Dual Mode v1.3 - Cloud Gemini Mode
# This file is documentation only. Do NOT copy these values into local .env unless testing cloud mode locally.
# On Render, set these in Render Dashboard > Environment.

APP_ENV=production
RUN_MIGRATIONS=true
HOST=0.0.0.0
PORT=5000
SECRET_KEY=<generated by Render or strong secret>
DATABASE_URL=<your Neon PostgreSQL connection string>

AUTH_REQUIRED=true
ALLOW_REGISTRATION=false
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
SECURITY_HEADERS_ENABLED=true
ENABLE_HSTS=true
TRUST_PROXY_HEADERS=true
RATE_LIMIT_ENABLED=true

# Cloud mode: Gemini for chat and Gemini embeddings for RAG.
AI_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODELS=gemini-2.5-flash,gemini-1.5-flash
GEMINI_API_KEY=<your Google AI Studio key>
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=768

OCR_ENABLED=true
TESSERACT_CMD=/usr/bin/tesseract
