# Application mode: development, testing, or production
APP_ENV=development

# Generate a strong random value before production.
SECRET_KEY=replace-with-a-long-random-secret

# User accounts and secure sessions
AUTH_REQUIRED=true
ALLOW_REGISTRATION=false
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
REMEMBER_COOKIE_DAYS=30
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
PASSWORD_MIN_LENGTH=10

DATABASE_URL=postgresql://postgres:YOUR_DATABASE_PASSWORD@localhost:5432/ai_studio_db

# AI provider
# AI provider. Options: ollama, openai, openrouter, gemini, anthropic
AI_PROVIDER=ollama

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODELS=gpt-4o-mini

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_MODELS=openai/gpt-4o-mini

# Google Gemini
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MODELS=gemini-1.5-flash

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_MODEL=claude-3-5-haiku-latest
ANTHROPIC_MODELS=claude-3-5-haiku-latest

OLLAMA_URL=http://localhost:11434
EMBEDDING_MODEL=embeddinggemma

RAG_TOP_K=5
RAG_CHUNK_SIZE=450
RAG_CHUNK_OVERLAP=80

OCR_ENABLED=true
TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
OCR_LANGUAGE=eng
OCR_TESSERACT_CONFIG=--oem 3 --psm 3
OCR_MIN_TEXT_CHARACTERS=40
MAX_PDF_PAGES=100
OCR_MAX_PDF_PAGES=25
OCR_PDF_DPI=200
OCR_MAX_IMAGE_PIXELS=25000000

# Website knowledge indexing
WEBSITE_CONNECT_TIMEOUT=5
WEBSITE_READ_TIMEOUT=15
WEBSITE_MAX_RESPONSE_BYTES=2000000
WEBSITE_MAX_REDIRECTS=3
WEBSITE_MAX_TEXT_CHARACTERS=500000
WEBSITE_MIN_TEXT_CHARACTERS=120
WEBSITE_RESPECT_ROBOTS=true
WEBSITE_USER_AGENT=AI-Studio-KnowledgeIndexer/1.0
WEBSITE_CRAWLER_DEFAULT_MAX_PAGES=25
WEBSITE_CRAWLER_MAX_PAGES=100
WEBSITE_CRAWLER_DEFAULT_DEPTH=2
WEBSITE_CRAWLER_MAX_DEPTH=5
WEBSITE_CRAWLER_DISCOVERY_BYTES=750000
WEBSITE_CRAWLER_SITEMAP_BYTES=1000000
WEBSITE_CRAWLER_MAX_SITEMAPS=8

LOG_LEVEL=INFO
LOG_MAX_BYTES=2000000
LOG_BACKUP_COUNT=5

HEALTH_HTTP_TIMEOUT=3
AUTO_CREATE_DATABASE=false

SECURITY_HEADERS_ENABLED=true
ENABLE_HSTS=false
TRUST_PROXY_HEADERS=false

# Chat attachments and vision
MAX_CONTENT_LENGTH=26214400
# Leave blank to auto-detect an installed Ollama vision model.
VISION_MODEL=
ATTACHMENT_MAX_FILES=5
ATTACHMENT_MAX_FILE_BYTES=20971520
ATTACHMENT_MAX_TOTAL_BYTES=41943040

# Social knowledge sources
SOCIAL_MAX_MANUAL_CHARACTERS=200000
SOCIAL_MIN_TEXT_CHARACTERS=40

# Optional: enables automatic Google Business Profile import through Places API.
# Create a restricted Google Maps Platform key, enable Places API, and never commit the real key.
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_LANGUAGE_CODE=en
GOOGLE_PLACES_MAX_REVIEWS=5

# Workspace backup safety limits
WORKSPACE_BACKUP_MAX_MEMBERS=5000
WORKSPACE_BACKUP_MAX_UNCOMPRESSED_BYTES=1000000000

# Admin analytics and abuse protection
METRICS_ENABLED=true
HEALTH_HISTORY_INTERVAL_SECONDS=300
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CHAT_PER_MINUTE=30
RATE_LIMIT_API_PER_MINUTE=120
RATE_LIMIT_UPLOADS_PER_10_MINUTES=20
RATE_LIMIT_LOGIN_ATTEMPTS=10
RATE_LIMIT_LOGIN_WINDOW_SECONDS=900
