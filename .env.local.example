# AI Studio Dual Mode v1.3 - Local Ollama Mode
# Copy this file to .env only on your local computer.
# Do NOT upload real secrets or local .env files to GitHub.

APP_ENV=development
SECRET_KEY=development-only-local-secret-change-me

# Local mode: AI and embeddings both use Ollama on your computer.
AI_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=embeddinggemma

# Choose a local database. SQLite is easiest for beginner local testing.
DATABASE_URL=sqlite:///ai_studio_local.db

# Local authentication. Set true if you want to test login locally.
AUTH_REQUIRED=false
ALLOW_REGISTRATION=true
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax

# Local OCR. Update this path if Tesseract is installed somewhere else.
OCR_ENABLED=true
TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
OCR_LANGUAGE=eng

# RAG and upload settings
RAG_TOP_K=5
RAG_CHUNK_SIZE=450
RAG_CHUNK_OVERLAP=80
MAX_CONTENT_LENGTH=26214400
ATTACHMENT_MAX_FILES=5
ATTACHMENT_MAX_FILE_BYTES=20971520
ATTACHMENT_MAX_TOTAL_BYTES=41943040

# Local security/development
SECURITY_HEADERS_ENABLED=true
ENABLE_HSTS=false
TRUST_PROXY_HEADERS=false
RATE_LIMIT_ENABLED=false
LOG_LEVEL=INFO
